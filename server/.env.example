# ── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001

# ── Base de datos (Turso) ─────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=tu_token_de_turso

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_al_menos_64_caracteres
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción: solo el dominio de tu frontend
ALLOWED_ORIGINS=https://tu-app.vercel.app

# ── Stripe (opcional por ahora) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_tu_key
STRIPE_WEBHOOK_SECRET=whsec_tu_secret
